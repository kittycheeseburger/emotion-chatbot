APP_NAME=Emotion Chatbot API
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Put the provided GLM API key here in your local backend/.env file.
GLM_API_KEY=
GLM_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.7-flash

# glm: use GLM-4.7-Flash for chat replies.
# auto: try OpenAI first, fall back to RAG when OpenAI is unavailable.
# rag: local RAG reply, fastest and no external API.
# openai/chatgpt: use OpenAI Responses API.
CHAT_REPLY_MODE=glm
